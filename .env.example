# ── 数据库 (PostgreSQL + pgvector，部署于 Railway) ──────────────
# 本地开发可使用本地 Postgres；生产使用 Railway 提供的连接串
DATABASE_URL="postgresql://user:password@localhost:5432/investment_workbench"

# ── 应用配置 ────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="投资工作台"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# 说明：本平台采用「用户自带 API Key」模式，
# 平台不存储任何 AI 服务（DeepSeek / Claude / 通义千问）的 API Key。
# Key 由用户在浏览器端输入，仅在单次请求中透传，不落库、不记录日志。

# ── 认证 (NextAuth.js) ──────────────────────────────────────
# NEXTAUTH_SECRET：用于签发/校验 JWT 的密钥，必填。
# 生成方式：openssl rand -base64 32   （或 npx auth secret）
NEXTAUTH_SECRET="请替换为随机字符串"
# NEXTAUTH_URL：站点完整地址。本地为 http://localhost:3000，生产填实际域名。
NEXTAUTH_URL="http://localhost:3000"

# ── GitHub OAuth（可选）─────────────────────────────────────
# 在 https://github.com/settings/developers 新建 OAuth App，
# 回调地址填 <NEXTAUTH_URL>/api/auth/callback/github。
# 不填则登录页不显示 GitHub 入口，仅保留邮箱+密码登录。
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ── 加密 ────────────────────────────────────────────────────
# ENCRYPTION_KEY：AES-256-GCM 主密钥，32 字节 / 64 位十六进制，
# 用于加密存储用户的 AI API Key。必填。
# 生成方式：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 注意：更换此密钥会导致已加密的 API Key 无法解密。
ENCRYPTION_KEY=""
